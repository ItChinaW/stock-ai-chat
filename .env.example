# ── 数据库 ────────────────────────────────────────────────
DATABASE_URL="mysql://user:password@localhost:3306/vibe_portfolio"

# ── AI 大模型（至少配置一个，否则 AI 功能自动隐藏）────────
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
GEMINI_API_KEY=""         # Google Gemini
DASHSCOPE_API_KEY=""      # 通义千问
ZHIPU_API_KEY=""          # 智谱 GLM
MINIMAX_API_KEY=""        # MiniMax

# ── 视觉识别（持仓截图导入）────────────────────────────────
# 可选值：zhipu（默认，免费）| qwen | openai
# 不配置则持仓导入按钮自动隐藏
VISION_PROVIDER=zhipu

# ── 币安 API（加密货币量化机器人，不需要可留空）────────────
BIAN_API_KEY=""
BIAN_API_SECRET=""

# ── Cron 鉴权（定时任务，本地开发可随意填）────────────────
CRON_SECRET="your-cron-secret"
